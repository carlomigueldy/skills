# Local Supabase (see docker-compose.yml at the repo root) or a hosted
# Supabase project's API settings.
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=

# Leave blank locally; set in CI/hosting env vars for staging & prod.
VITE_SENTRY_DSN=

# PostHog product analytics (free tier). Leave blank to disable.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
