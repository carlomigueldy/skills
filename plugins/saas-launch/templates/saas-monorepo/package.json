{
  "name": "{{PRODUCT_SLUG}}",
  "version": "0.1.0",
  "private": true,
  "description": "{{PRODUCT_DESCRIPTION}}",
  "license": "UNLICENSED",
  "author": {
    "name": "{{PRODUCT_NAME}}",
    "email": "{{CONTACT_EMAIL}}"
  },
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "verify": "turbo run lint typecheck build && turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\" --ignore-unknown",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
