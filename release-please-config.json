{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "separate-pull-requests": true,
  "sequential-calls": true,
  "tag-separator": "--",
  "include-component-in-tag": true,
  "packages": {
    "plugins/saas-launch": {
      "release-type": "simple",
      "component": "saas-launch",
      "package-name": "saas-launch",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "plugins/product-foundry": {
      "release-type": "simple",
      "component": "product-foundry",
      "package-name": "product-foundry",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": ".codex-plugin/plugin.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "plugins/grok-ultracode": {
      "release-type": "simple",
      "component": "grok-ultracode",
      "package-name": "grok-ultracode",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
